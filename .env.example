# Flask Configuration
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=your-secret-key-here

# API Authentication
API_KEY=your-api-key-here

# CORS - comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Model paths
CONFLICT_MODEL_PATH=backend/models/conflict_detector.pkl
DELAY_MODEL_PATH=backend/models/delay_predictor.pkl

# Rate limiting
RATE_LIMIT_DEFAULT=100 per hour
RATE_LIMIT_PREDICT=200 per hour
RATE_LIMIT_BATCH=20 per hour
